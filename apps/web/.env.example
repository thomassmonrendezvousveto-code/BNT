# Baby Next Time — variables d'environnement

# === Email (envoi du kit personnalisé) ===
# Sans clé Resend, l'envoi est simulé en console (dev OK).
# Pour activer le vrai envoi : créer un compte sur https://resend.com,
# vérifier le domaine babynexttime.fr, puis :
RESEND_API_KEY=

# Adresse "From" affichée par défaut dans les mails (doit appartenir au domaine vérifié)
KIT_EMAIL_FROM="Baby Next Time <contact@babynexttime.fr>"
